<!-- Hidden canvas for processing -->
<canvas id="mainCanvas" style="display:none"></canvas>
<canvas id="bgCanvas" style="display:none"></canvas>

<script>
  let selectedFile = null;
  let selectedFill = 'blur';
  let isConverting = false;
  let mediaRecorder = null;
  let recordedChunks = [];
  let outputBlob = null;
  let animFrame = null;
  let videoEl = null;

  // File input
  document.getElementById('fileInput').addEventListener('change', e => {
    if (e.target.files[0]) handleFile(e.target.files[0]);
  });

  // Drag and drop
  const dropZone = document.getElementById('dropZone');
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    const f = e.dataTransfer.files[0];
    if (f && f.type.startsWith('video/')) handleFile(f);
  });

  function formatBytes(b) {
    if (b < 1024*1024) return (b/1024).toFixed(1) + ' KB';
    return (b/(1024*1024)).toFixed(1) + ' MB';
  }

  function handleFile(file) {
    selectedFile = file;
    document.getElementById('fileName').textContent = file.name;
    document.getElementById('fileMeta').textContent = `${formatBytes(file.size)} · ${file.type || 'video'}`;
    document.getElementById('fileInfo').classList.add('visible');
    document.getElementById('settingsPanel').classList.add('visible');
    document.getElementById('downloadBtn').classList.remove('visible');
    document.getElementById('resetBtn').style.display = 'none';
    document.getElementById('progressWrap').classList.remove('visible');

    // Load preview
    const url = URL.createObjectURL(file);
    const vid = document.getElementById('previewVideo');
    vid.src = url;
    vid.load();
    vid.onloadedmetadata = () => {
      document.getElementById('inputDims').textContent = `${vid.videoWidth} × ${vid.videoHeight}`;
      // Calculate output dims
      const outW = vid.videoHeight; // portrait width = landscape height
      const outH = Math.round(vid.videoHeight * 16/9);
      document.getElementById('outputDims').textContent = `${vid.videoHeight} × ${Math.round(vid.videoWidth * 16/9)}`;
    };
    vid.play().catch(()=>{});
  }

  function selectFill(el) {
    document.querySelectorAll('.fill-opt').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    selectedFill = el.dataset.fill;
  }

  function setStep(n) {
    for (let i = 1; i <= 4; i++) {
      const s = document.getElementById('step' + i);
      s.classList.remove('done', 'active');
      if (i < n) s.classList.add('done');
      else if (i === n) s.classList.add('active');
    }
  }

  function setProgress(pct, status) {
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressPct').textContent = Math.round(pct) + '%';
    document.getElementById('progressStatus').textContent = status;
  }

  async function startConversion() {
    if (!selectedFile || isConverting) return;
    isConverting = true;

    const convertBtn = document.getElementById('convertBtn');
    convertBtn.disabled = true;
    convertBtn.innerHTML = `<svg class="spin" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 018 8" stroke="white" stroke-width="2" stroke-linecap="round"/></svg> CONVERTING...`;

    document.getElementById('progressWrap').classList.add('visible');
    document.getElementById('downloadBtn').classList.remove('visible');
    document.getElementById('resetBtn').style.display = 'none';

    setProgress(0, 'Loading video...');
    setStep(1);

    await new Promise(r => setTimeout(r, 100));

    const qualitySetting = document.getElementById('qualitySelect').value;
    const resSetting = document.getElementById('resolutionSelect').value;
    const formatSetting = document.getElementById('formatSelect').value;

    const bpsMap = { high: 8000000, medium: 4000000, low: 1500000 };
    const bitsPerSecond = bpsMap[qualitySetting];

    // Create video element
    videoEl = document.createElement('video');
    videoEl.src = URL.createObjectURL(selectedFile);
    videoEl.muted = true;
    videoEl.playsinline = true;

    await new Promise((res, rej) => {
      videoEl.onloadedmetadata = res;
      videoEl.onerror = rej;
    });

    const srcW = videoEl.videoWidth;
    const srcH = videoEl.videoHeight;

    // Output dimensions
    let outW, outH;
    if (resSetting === 'auto') {
      // Portrait: height stays same, width = height * 9/16 — actually keep height, compute width
      // For 9:16 portrait from landscape (srcW x srcH):
      // Output height = srcW (rotated), width = srcH * 9/16
      outH = srcW; // the longest side becomes height
      outW = Math.round(outH * 9 / 16);
    } else {
      const [w, h] = resSetting.split('x').map(Number);
      outW = w; outH = h;
    }

    const canvas = document.getElementById('mainCanvas');
    canvas.width = outW;
    canvas.height = outH;
    const ctx = canvas.getContext('2d');

    const bgCanvas = document.getElementById('bgCanvas');
    bgCanvas.width = outW;
    bgCanvas.height = outH;
    const bgCtx = bgCanvas.getContext('2d');

    setProgress(10, 'Setting up encoder...');
    setStep(2);
    await new Promise(r => setTimeout(r, 100));

    recordedChunks = [];

    // Determine MIME type
    let mimeType = formatSetting;
    if (!MediaRecorder.isTypeSupported(mimeType)) {
      // Fallback
      const fallbacks = ['video/webm;codecs=vp9','video/webm;codecs=vp8','video/webm','video/mp4'];
      mimeType = fallbacks.find(t => MediaRecorder.isTypeSupported(t)) || 'video/webm';
    }

    const stream = canvas.captureStream(30);
    mediaRecorder = new MediaRecorder(stream, { mimeType, videoBitsPerSecond: bitsPerSecond });

    mediaRecorder.ondataavailable = e => {
      if (e.data.size > 0) recordedChunks.push(e.data);
    };

    mediaRecorder.onstop = () => {
      setProgress(95, 'Finalizing...');
      setStep(4);
      const ext = mimeType.includes('mp4') ? 'mp4' : 'webm';
      outputBlob = new Blob(recordedChunks, { type: mimeType });
      const url = URL.createObjectURL(outputBlob);
      const dlBtn = document.getElementById('downloadBtn');
      dlBtn.href = url;
      dlBtn.download = `portrait_${Date.now()}.${ext}`;
      dlBtn.classList.add('visible');

      setTimeout(() => {
        setProgress(100, `Done! ${formatBytes(outputBlob.size)} · Ready to download`);
        convertBtn.disabled = false;
        convertBtn.innerHTML = `<svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 2v6M11 14v6M2 11h6M14 11h6" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.5"/><circle cx="11" cy="11" r="3.5" fill="white"/></svg> CONVERT AGAIN`;
        document.getElementById('resetBtn').style.display = 'block';
        isConverting = false;
        cancelAnimationFrame(animFrame);
        videoEl.pause();
      }, 300);
    };

    mediaRecorder.start(1000);
    setProgress(15, 'Processing frames...');
    setStep(3);

    videoEl.currentTime = 0;
    await new Promise(r => setTimeout(r, 200));
    videoEl.play();

    const duration = videoEl.duration;
    let lastTime = performance.now();

    // Scale: fit video in center of portrait canvas
    const scale = Math.min(outW / srcW, outH / srcH);
    const drawW = srcW * scale;
    const drawH = srcH * scale;
    const dx = (outW - drawW) / 2;
    const dy = (outH - drawH) / 2;

    // BG scale: fill canvas
    const bgScale = Math.max(outW / srcW, outH / srcH);
    const bgW = srcW * bgScale;
    const bgH = srcH * bgScale;
    const bgX = (outW - bgW) / 2;
    const bgY = (outH - bgH) / 2;

    function renderFrame() {
      const now = performance.now();
      lastTime = now;

      ctx.clearRect(0, 0, outW, outH);

      // Draw background based on fill mode
      if (selectedFill === 'black') {
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, outW, outH);
      } else if (selectedFill === 'blur') {
        // Draw stretched video as bg
        ctx.drawImage(videoEl, bgX, bgY, bgW, bgH);
        // Blur via downscale trick (fast)
        ctx.filter = 'blur(18px) brightness(0.6)';
        ctx.drawImage(canvas, 0, 0, outW/4, outH/4, 0, 0, outW, outH);
        ctx.filter = 'none';
        // Redraw main
        ctx.drawImage(videoEl, bgX, bgY, bgW, bgH);
        ctx.filter = 'blur(20px) brightness(0.55)';
        ctx.drawImage(canvas, 0, 0);
        ctx.filter = 'none';
      } else if (selectedFill === 'mirror') {
        ctx.save();
        ctx.translate(outW, 0);
        ctx.scale(-1, 1);
        ctx.drawImage(videoEl, bgX, bgY, bgW, bgH);
        ctx.restore();
      } else if (selectedFill === 'stretch') {
        ctx.drawImage(videoEl, 0, 0, outW, outH);
      }

      // Draw main centered video on top
      if (selectedFill !== 'stretch') {
        ctx.drawImage(videoEl, dx, dy, drawW, drawH);
      }

      // Progress
      if (!videoEl.paused && !videoEl.ended) {
        const pct = 15 + (videoEl.currentTime / duration) * 75;
        setProgress(pct, `Processing frame ${Math.round(videoEl.currentTime)}s / ${Math.round(duration)}s`);
        animFrame = requestAnimationFrame(renderFrame);
      } else if (videoEl.ended) {
        setTimeout(() => {
          if (mediaRecorder && mediaRecorder.state !== 'inactive') {
            mediaRecorder.stop();
          }
        }, 500);
      } else {
        animFrame = requestAnimationFrame(renderFrame);
      }
    }

    videoEl.onended = () => {
      cancelAnimationFrame(animFrame);
      setTimeout(() => {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
          mediaRecorder.stop();
        }
      }, 600);
    };

    renderFrame();
  }

  function resetAll() {
    if (animFrame) cancelAnimationFrame(animFrame);
    if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
    if (videoEl) { videoEl.pause(); videoEl.src = ''; }

    selectedFile = null;
    isConverting = false;
    recordedChunks = [];
    outputBlob = null;

    document.getElementById('fileInfo').classList.remove('visible');
    document.getElementById('settingsPanel').classList.remove('visible');
    document.getElementById('fileInput').value = '';
    document.getElementById('progressWrap').classList.remove('visible');
    document.getElementById('downloadBtn').classList.remove('visible');
    document.getElementById('resetBtn').style.display = 'none';

    const convertBtn = document.getElementById('convertBtn');
    convertBtn.disabled = false;
    convertBtn.innerHTML = `<svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 2v6M11 14v6M2 11h6M14 11h6" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.5"/><circle cx="11" cy="11" r="3.5" fill="white"/></svg> CONVERT TO PORTRAIT`;
  }
</script>
